<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.immigrationconsultingfirm_project_cse213.AppointmentCoordinator.ScheduleNewAppointment">
   <children>
      <TextField layoutX="118.0" layoutY="34.0" prefHeight="63.0" prefWidth="353.0" text="Schedule New Appointment">
         <font>
            <Font name="System Bold Italic" size="24.0" />
         </font>
      </TextField>
      <ComboBox fx:id="clientCombo" layoutX="138.0" layoutY="139.0" prefWidth="150.0" />
      <ComboBox fx:id="consultantCombo" layoutX="138.0" layoutY="175.0" prefWidth="150.0" />
      <DatePicker fx:id="datePicker" layoutX="147.0" layoutY="225.0" />
      <Button fx:id="checkAvailabilityBtn" layoutX="61.0" layoutY="280.0" mnemonicParsing="false" onAction="#handleCheckAvailability" text="Check Availability" />
      <Button fx:id="saveAppointmentBtn" layoutX="213.0" layoutY="280.0" mnemonicParsing="false" onAction="#handleSaveAppointment" text="Save Appointment" />
      <Button fx:id="cancelBtn" layoutX="350.0" layoutY="280.0" mnemonicParsing="false" onAction="#handleCancel" text="cancel" />
      <Label layoutX="415.0" layoutY="191.0" prefHeight="51.0" prefWidth="114.0" />
      <Label layoutX="56.0" layoutY="143.0" text="Client" />
      <Label layoutX="57.0" layoutY="179.0" text="Counsaltant" />
      <Label layoutX="75.0" layoutY="229.0" text="Date" />
      <Label fx:id="messagelabel" layoutX="147.0" layoutY="342.0" prefHeight="44.0" prefWidth="246.0" text="Show message" />
   </children>
</AnchorPane>
