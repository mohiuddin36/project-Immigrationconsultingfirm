<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.javafxproject.BookServiceController"
            prefHeight="450.0" prefWidth="650.0">

    <children>

        <Label text="BOOK SERVICE"
               layoutX="240" layoutY="20"
               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <Label text="Full Name:" layoutX="80" layoutY="80"/>
        <TextField fx:id="nameField" layoutX="220" layoutY="75" prefWidth="300"/>

        <Label text="Phone:" layoutX="80" layoutY="120"/>
        <TextField fx:id="phoneField" layoutX="220" layoutY="115" prefWidth="300"/>

        <Label text="Service:" layoutX="80" layoutY="160"/>
        <ComboBox fx:id="serviceCombo" layoutX="220" layoutY="155" prefWidth="300"/>

        <Label text="Date:" layoutX="80" layoutY="200"/>
        <DatePicker fx:id="datePicker" layoutX="220" layoutY="195" prefWidth="300"/>

        <Label text="Time:" layoutX="80" layoutY="240"/>
        <TextField fx:id="timeField" layoutX="220" layoutY="235" prefWidth="300"/>

        <Label text="Address:" layoutX="80" layoutY="280"/>
        <TextArea fx:id="addressArea" layoutX="220" layoutY="275" prefWidth="300" prefHeight="70"/>

        <!-- Previous Button -->
        <Button text="Previous"
                layoutX="100"
                layoutY="370"
                prefWidth="120"
                onAction="#goBack"/>

        <!-- Submit Button -->
        <Button text="Submit"
                layoutX="260"
                layoutY="370"
                prefWidth="120"
                onAction="#handleSubmit"/>

    </children>
</AnchorPane>