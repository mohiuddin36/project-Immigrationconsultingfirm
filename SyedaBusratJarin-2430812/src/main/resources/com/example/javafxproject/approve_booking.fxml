<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.javafxproject.ApproveBookingController"
            prefHeight="500.0" prefWidth="700.0">

    <children>

        <!-- TITLE -->
        <Label text="APPROVE BOOKINGS"
               layoutX="240" layoutY="20"
               style="-fx-font-size: 20px; -fx-font-weight: bold;" />

        <!-- TABLE -->
        <TableView fx:id="table"
                   layoutX="50" layoutY="70"
                   prefWidth="600" prefHeight="300">

            <columns>
                <TableColumn fx:id="nameCol" text="Name" prefWidth="120"/>
                <TableColumn fx:id="serviceCol" text="Service" prefWidth="120"/>
                <TableColumn fx:id="dateCol" text="Date" prefWidth="120"/>
                <TableColumn fx:id="statusCol" text="Status" prefWidth="120"/>
            </columns>

        </TableView>

        <!-- BUTTON -->
        <Button text="Approve Selected"
                layoutX="270"
                layoutY="400"
                prefWidth="160"
                onAction="#approveBooking"/>

        <!-- PREVIOUS BUTTON -->
        <Button text="Previous"
                layoutX="50"
                layoutY="450"
                prefWidth="150"
                onAction="#goBack"/>

    </children>
</AnchorPane>