<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.javafxproject.LoginController"
            prefHeight="420.0" prefWidth="600.0">

    <children>

        <!-- Title -->
        <Label layoutX="240" layoutY="40"
               text="LOGIN"
               style="-fx-font-size: 22px; -fx-font-weight: bold;" />

        <!-- Username -->
        <TextField fx:id="usernameField"
                   layoutX="180" layoutY="120"
                   prefWidth="240"
                   promptText="Username"/>

        <!-- Password -->
        <PasswordField fx:id="passwordField"
                       layoutX="180" layoutY="170"
                       prefWidth="240"
                       promptText="Password"/>

        <!-- Login as Client -->
        <Button layoutX="180" layoutY="230"
                prefWidth="240"
                text="Login as Client"
                onAction="#loginClient"/>

        <!-- Login as Receptionist -->
        <Button layoutX="180" layoutY="280"
                prefWidth="240"
                text="Login as Receptionist"
                onAction="#loginReceptionist"/>

        <!-- Register Button -->
        <Button layoutX="180" layoutY="330"
                prefWidth="240"
                text="Register"
                onAction="#openRegister"/>

    </children>

</AnchorPane>