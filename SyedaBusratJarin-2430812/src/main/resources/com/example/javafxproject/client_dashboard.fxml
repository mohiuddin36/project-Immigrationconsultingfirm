<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.javafxproject.ClientDashboardController"
            prefHeight="420.0" prefWidth="650.0">

    <children>

        <!-- TITLE -->
        <Label layoutX="230" layoutY="20"
               text="CLIENT DASHBOARD"
               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <!-- ROW 1 -->
        <Button layoutX="50" layoutY="90"
                text="Book Service"
                prefWidth="170"
                onAction="#bookService"/>

        <Button layoutX="240" layoutY="90"
                text="View Appointments"
                prefWidth="170"
                onAction="#viewAppointments"/>

        <Button layoutX="430" layoutY="90"
                text="Cancel Booking"
                prefWidth="170"
                onAction="#cancelBooking"/>

        <!-- ROW 2 -->
        <Button layoutX="50" layoutY="170"
                text="Payment"
                prefWidth="170"
                onAction="#payment"/>

        <Button layoutX="240" layoutY="170"
                text="Profile"
                prefWidth="170"
                onAction="#profile"/>

        <Button layoutX="430" layoutY="170"
                text="Messages"
                prefWidth="170"
                onAction="#messages"/>

        <!-- ROW 3 -->
        <Button layoutX="150" layoutY="250"
                text="History"
                prefWidth="170"
                onAction="#history"/>

        <Button layoutX="340" layoutY="250"
                text="Feedback"
                prefWidth="170"
                onAction="#feedback"/>

    </children>
</AnchorPane>