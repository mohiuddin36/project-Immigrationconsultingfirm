<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.javafxproject.RegisterController"
            prefHeight="520.0" prefWidth="600.0">

    <children>

        <Label layoutX="230" layoutY="20"
               text="REGISTER"
               style="-fx-font-size: 22px; -fx-font-weight: bold;" />

        <!-- Username -->
        <TextField fx:id="usernameField"
                   layoutX="180" layoutY="70"
                   prefWidth="240"
                   promptText="Username"/>

        <!-- Name -->
        <TextField fx:id="nameField"
                   layoutX="180" layoutY="110"
                   prefWidth="240"
                   promptText="Full Name"/>

        <!-- Phone -->
        <TextField fx:id="phoneField"
                   layoutX="180" layoutY="150"
                   prefWidth="240"
                   promptText="Phone"/>

        <!-- Email -->
        <TextField fx:id="emailField"
                   layoutX="180" layoutY="190"
                   prefWidth="240"
                   promptText="Email"/>

        <!-- Address -->
        <TextArea fx:id="addressField"
                  layoutX="180" layoutY="230"
                  prefWidth="240" prefHeight="60"
                  promptText="Address"/>

        <!-- Password -->
        <PasswordField fx:id="passwordField"
                       layoutX="180" layoutY="310"
                       prefWidth="240"
                       promptText="Password"/>

        <!-- Role -->
        <ComboBox fx:id="roleCombo"
                  layoutX="180" layoutY="350"
                  prefWidth="240"
                  promptText="Select Role"/>

        <!-- Register -->
        <Button text="Register"
                layoutX="180" layoutY="400"
                prefWidth="240"
                onAction="#registerUser"/>

        <!-- Back -->
        <Button text="Back to Login"
                layoutX="180" layoutY="440"
                prefWidth="240"
                onAction="#goBack"/>

    </children>
</AnchorPane>