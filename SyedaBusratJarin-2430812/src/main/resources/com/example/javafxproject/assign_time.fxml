<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.javafxproject.AssignTimeController"
            prefHeight="400" prefWidth="600">

    <children>

        <Label text="ASSIGN TIME"
               layoutX="240" layoutY="30"
               style="-fx-font-size: 18px; -fx-font-weight: bold;" />

        <TableView fx:id="table"
                   layoutX="40" layoutY="80"
                   prefWidth="520" prefHeight="200">

            <columns>
                <TableColumn fx:id="nameCol" text="Name"/>
                <TableColumn fx:id="serviceCol" text="Service"/>
                <TableColumn fx:id="timeCol" text="Time"/>
            </columns>

        </TableView>

        <TextField fx:id="timeField"
                   layoutX="200" layoutY="300"
                   promptText="Enter new time"/>

        <Button text="Assign"
                layoutX="260"
                layoutY="340"
                onAction="#assignTime"/>

        <!-- PREVIOUS BUTTON -->
        <Button text="Previous"
                layoutX="50"
                layoutY="360"
                prefWidth="150"
                onAction="#goBack"/>

    </children>
</AnchorPane>