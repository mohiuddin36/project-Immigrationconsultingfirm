<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.javafxproject.FeedbackController"
            prefHeight="450.0" prefWidth="650.0">

    <children>

        <Label text="FEEDBACK"
               layoutX="270" layoutY="20"
               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <Label text="Your Name:" layoutX="80" layoutY="90"/>
        <TextField fx:id="nameField"
                   layoutX="200" layoutY="85"
                   prefWidth="350"/>

        <Label text="Rating:" layoutX="80" layoutY="140"/>
        <ComboBox fx:id="ratingCombo"
                  layoutX="200" layoutY="135"
                  prefWidth="350"/>

        <Label text="Comment:" layoutX="80" layoutY="190"/>
        <TextArea fx:id="commentArea"
                  layoutX="200" layoutY="185"
                  prefWidth="350" prefHeight="120"/>

        <!-- Submit Button -->
        <Button text="Submit"
                layoutX="300"
                layoutY="330"
                prefWidth="120"
                onAction="#submitFeedback"/>

        <!-- Previous Button -->
        <Button text="Previous"
                layoutX="100"
                layoutY="330"
                prefWidth="120"
                onAction="#goBack"/>

    </children>
</AnchorPane>