<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.javafxproject.ProfileController"
            prefHeight="520.0" prefWidth="650.0">

    <children>

        <Label text="PROFILE"
               layoutX="280" layoutY="20"
               style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

        <!-- Username -->
        <Label text="Username:" layoutX="80" layoutY="80"/>
        <TextField fx:id="usernameField"
                   layoutX="220" layoutY="75"
                   prefWidth="300"/>

        <!-- Name -->
        <Label text="Full Name:" layoutX="80" layoutY="120"/>
        <TextField fx:id="nameField"
                   layoutX="220" layoutY="115"
                   prefWidth="300"/>

        <!-- Phone -->
        <Label text="Phone:" layoutX="80" layoutY="160"/>
        <TextField fx:id="phoneField"
                   layoutX="220" layoutY="155"
                   prefWidth="300"/>

        <!-- Email -->
        <Label text="Email:" layoutX="80" layoutY="200"/>
        <TextField fx:id="emailField"
                   layoutX="220" layoutY="195"
                   prefWidth="300"/>

        <!-- Address -->
        <Label text="Address:" layoutX="80" layoutY="240"/>
        <TextArea fx:id="addressField"
                  layoutX="220" layoutY="235"
                  prefWidth="300"
                  prefHeight="80"/>

        <!-- Password -->
        <Label text="Password:" layoutX="80" layoutY="330"/>
        <PasswordField fx:id="passwordField"
                       layoutX="220" layoutY="325"
                       prefWidth="300"/>

        <!-- Buttons -->

        <Button text="Previous"
                layoutX="100"
                layoutY="420"
                prefWidth="120"
                onAction="#goBack"/>

        <Button text="Update"
                layoutX="260"
                layoutY="420"
                prefWidth="120"
                onAction="#updateProfile"/>

        <Button text="Logout"
                layoutX="420"
                layoutY="420"
                prefWidth="120"
                onAction="#logout"/>

    </children>
</AnchorPane>