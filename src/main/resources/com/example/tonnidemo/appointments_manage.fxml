<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.tonnidemo.AppointmentsManageController"
            prefHeight="450" prefWidth="650">

    <children>

        <Label text="APPOINTMENTS"
               layoutX="250" layoutY="10"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <!-- TABLE -->
        <TableView fx:id="appointmentTable"
                   layoutX="10" layoutY="40"
                   prefHeight="220" prefWidth="620">

            <columns>

                <TableColumn fx:id="colAppointmentId" text="ID" prefWidth="80"/>
                <TableColumn fx:id="colName" text="Name" prefWidth="120"/>
                <TableColumn fx:id="colVisaType" text="Visa" prefWidth="120"/>
                <TableColumn fx:id="colCountry" text="Country" prefWidth="120"/>
                <TableColumn fx:id="colDate" text="Date" prefWidth="80"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>

            </columns>

        </TableView>

        <!-- INPUT -->
        <ComboBox fx:id="statusComboBox"
                  layoutX="10" layoutY="280"
                  prefWidth="150"/>

        <TextField fx:id="officerField"
                   layoutX="170" layoutY="280"
                   prefWidth="150"
                   promptText="Officer"/>

        <!-- BUTTONS -->
        <Button text="Update"
                layoutX="330" layoutY="280"
                onAction="#handleUpdate"/>

        <Button text="Refresh"
                layoutX="410" layoutY="280"
                onAction="#handleRefresh"/>

        <Button text="View"
                layoutX="490" layoutY="280"
                onAction="#handleView"/>

        <Button text="Back"
                layoutX="10" layoutY="320"
                onAction="#goBack"/>

        <!-- DETAILS -->
        <Label fx:id="messageLabel"
               layoutX="10" layoutY="360"
               prefWidth="620"
               text="Select appointment..."
               style="-fx-border-color: gray; -fx-padding: 5;"/>

    </children>

</AnchorPane>