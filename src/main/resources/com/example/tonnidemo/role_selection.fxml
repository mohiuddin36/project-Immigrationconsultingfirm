<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tonnidemo.RoleSelectionController">

    <Label layoutX="200" layoutY="70" text="Select User Type">
        <font>
            <Font size="24"/>
        </font>
    </Label>

    <Button layoutX="220" layoutY="150"
            text="Client"
            prefWidth="160"
            prefHeight="40"
            onAction="#openClient"/>

    <Button layoutX="220" layoutY="210"
            text="Staff"
            prefWidth="160"
            prefHeight="40"
            onAction="#openStaff"/>

</AnchorPane>