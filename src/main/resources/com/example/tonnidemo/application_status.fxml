<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.tonnidemo.ApplicationStatusController">

    <children>

        <Label layoutX="200" layoutY="20" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="APPLICATION STATUS" />

        <TableView fx:id="applicationTable" layoutX="30" layoutY="60" prefHeight="220" prefWidth="540">

            <columns>
                <TableColumn fx:id="colAppId" prefWidth="80.66665649414062" text="App ID" />
                <TableColumn fx:id="colClientName" prefWidth="88.0" text="Client" />
                <TableColumn fx:id="colVisaType" prefWidth="99.99993896484375" text="Visa Type" />
                <TableColumn fx:id="colCountry" prefWidth="102.6666259765625" text="Country" />
                <TableColumn fx:id="colDate" prefWidth="81.33331298828125" text="Date" />
                <TableColumn fx:id="colStatus" prefWidth="86.0" text="Status" />
            </columns>

        </TableView>

        <Label fx:id="detailLabel" layoutX="30" layoutY="290" prefWidth="540" style="-fx-border-color: gray; -fx-padding: 10;" text="Select application to view details" />

        <Button layoutX="30" layoutY="330" onAction="#handleViewDetails" text="View Details" />

        <Button layoutX="150" layoutY="330" onAction="#handleRefresh" text="Refresh" />

        <Button layoutX="260" layoutY="330" onAction="#goBack" text="Back" />

    </children>

</AnchorPane>
