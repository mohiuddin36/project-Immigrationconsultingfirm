<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.tonnidemo.AppointmentController"
            prefHeight="500.0" prefWidth="700.0">

    <children>

        <Label text="BOOK APPOINTMENT"
               layoutX="250" layoutY="20"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <TextField fx:id="nameField"
                   layoutX="100" layoutY="80"
                   prefWidth="200"
                   promptText="Client Name"/>

        <ComboBox fx:id="visaTypeBox"
                  layoutX="100" layoutY="130"
                  prefWidth="200"/>

        <ComboBox fx:id="countryBox"
                  layoutX="100" layoutY="180"
                  prefWidth="200"/>

        <TextField fx:id="dateField"
                   layoutX="100" layoutY="230"
                   prefWidth="200"
                   promptText="Date"/>

        <RadioButton fx:id="morningRadio"
                     layoutX="100" layoutY="280"
                     text="Morning"/>

        <RadioButton fx:id="eveningRadio"
                     layoutX="200" layoutY="280"
                     text="Evening"/>

        <TextArea fx:id="noteArea"
                  layoutX="100" layoutY="320"
                  prefHeight="80" prefWidth="200"
                  promptText="Notes"/>

        <Button text="Book Appointment"
                layoutX="100" layoutY="420"
                onAction="#handleBook"/>

        <!-- BACK BUTTON (IMPORTANT FIX) -->
        <Button text="Back"
                layoutX="220" layoutY="420"
                onAction="#goBack"/>

        <!-- TABLE -->
        <TableView fx:id="appointmentTable"
                   layoutX="350" layoutY="80"
                   prefHeight="250" prefWidth="300">

            <columns>
                <TableColumn fx:id="nameCol" text="Name" prefWidth="100"/>
                <TableColumn fx:id="visaCol" text="Visa" prefWidth="100"/>
                <TableColumn fx:id="dateCol" text="Date" prefWidth="100"/>
            </columns>

        </TableView>

    </children>

</AnchorPane>