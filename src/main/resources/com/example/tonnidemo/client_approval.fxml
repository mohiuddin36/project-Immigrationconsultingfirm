<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.tonnidemo.ClientApprovalController"
            prefHeight="400.0" prefWidth="700.0">

    <children>

        <Label text="CLIENT APPROVAL"
               layoutX="250" layoutY="10"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <!-- TABLE -->
        <TableView fx:id="clientTable"
                   layoutX="20" layoutY="50"
                   prefHeight="250" prefWidth="650">

            <columns>

                <TableColumn fx:id="colClientId" text="ID" prefWidth="80"/>
                <TableColumn fx:id="colName" text="Name" prefWidth="120"/>
                <TableColumn fx:id="colBirthDate" text="Birth Date" prefWidth="100"/>
                <TableColumn fx:id="colAddress" text="Address" prefWidth="150"/>
                <TableColumn fx:id="colPhone" text="Phone" prefWidth="100"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="100"/>

            </columns>

        </TableView>

        <!-- BUTTONS -->
        <Button text="Approve"
                layoutX="20" layoutY="320"
                prefWidth="150"
                onAction="#handleApprove"/>

        <Button text="Reject"
                layoutX="180" layoutY="320"
                prefWidth="150"
                onAction="#handleReject"/>

        <Button text="Refresh"
                layoutX="340" layoutY="320"
                prefWidth="150"
                onAction="#handleRefresh"/>

        <!-- MESSAGE -->
        <Label fx:id="messageLabel"
               layoutX="20" layoutY="360"
               prefWidth="650"
               text="Select a client"
               style="-fx-border-color: gray; -fx-padding: 5;"/>

    </children>

</AnchorPane>