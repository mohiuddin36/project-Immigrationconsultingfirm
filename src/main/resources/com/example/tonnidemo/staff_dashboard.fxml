<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.tonnidemo.StaffDashboardController"
            prefHeight="400.0" prefWidth="600.0">

    <children>

        <Label text="STAFF DASHBOARD"
               layoutX="200" layoutY="20"
               style="-fx-font-size:18px; -fx-font-weight:bold;"/>

        <Button text="Appointments"
                layoutX="200" layoutY="80"
                prefWidth="200"
                onAction="#openAppointments"/>

        <Button text="Documents"
                layoutX="200" layoutY="130"
                prefWidth="200"
                onAction="#openDocuments"/>

        <Button text="Payments"
                layoutX="200" layoutY="180"
                prefWidth="200"
                onAction="#openPayments"/>

        <Button text="Clients"
                layoutX="200" layoutY="230"
                prefWidth="200"
                onAction="#openClients"/>

        <Button text="Notifications"
                layoutX="200" layoutY="280"
                prefWidth="200"
                onAction="#openNotifications"/>

        <Button text="LOGOUT"
                layoutX="20" layoutY="350"
                onAction="#goBack"/>

    </children>
</AnchorPane>