<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500" prefWidth="750" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.tonnidemo.ClientRegistrationController">

    <children>

        <!-- TITLE -->
        <Label layoutX="250" layoutY="10" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="CLIENT REGISTRATION" />

        <!-- INPUT FIELDS -->
        <TextField fx:id="nameField" layoutX="50" layoutY="60" prefWidth="200" promptText="Full Name" />

        <TextField fx:id="birthField" layoutX="50" layoutY="110" prefWidth="200" promptText="Birth Date (YYYY-MM-DD)" />

        <TextField fx:id="addressField" layoutX="50" layoutY="160" prefWidth="200" promptText="Address" />

        <TextField fx:id="phoneField" layoutX="50" layoutY="210" prefWidth="200" promptText="Phone Number" />

        <TextField fx:id="emailField" layoutX="50" layoutY="260" prefWidth="200" promptText="Email" />

        <!-- BUTTONS -->
        <Button layoutX="50" layoutY="320" onAction="#handleSave" prefWidth="200" text="Save Client" />

        <Button layoutX="50" layoutY="370" onAction="#goBack" prefWidth="200" text="Back to Dashboard" />

        <!-- TABLE -->
        <TableView fx:id="clientTable" layoutX="300" layoutY="60" prefHeight="380" prefWidth="420">

            <columns>

                <TableColumn fx:id="colId" prefWidth="60" text="ID" />

                <TableColumn fx:id="colName" prefWidth="100" text="Name" />

                <TableColumn fx:id="colBirth" prefWidth="100" text="Birth Date" />

                <TableColumn fx:id="colPhone" prefWidth="80" text="Phone" />

                <TableColumn fx:id="colEmail" prefWidth="77.33331298828125" text="Email" />

            </columns>

        </TableView>

    </children>

</AnchorPane>
