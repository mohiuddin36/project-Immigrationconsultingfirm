<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="545.0" prefWidth="744.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.immigrationconsultingfirm_project_cse213.DocumentationAndTranslation.TranslatingController">

    <Label alignment="CENTER" layoutX="200.0" layoutY="10.0" prefWidth="350.0" text="Translate Client Documents">
        <font>
            <Font size="18" />
        </font>
    </Label>

    <TableView fx:id="tableView" layoutX="20.0" layoutY="50.0" prefHeight="250.0" prefWidth="500.0">
        <columns>
            <TableColumn fx:id="docNameColumn" prefWidth="200" text="Document Name" />
            <TableColumn fx:id="languageColumn" prefWidth="150" text="Language" />
            <TableColumn fx:id="statusColumn" prefWidth="150" text="Status" />
        </columns>
    </TableView>

    <TextArea fx:id="translationArea" layoutX="20.0" layoutY="310.0" prefHeight="150.0" prefWidth="500.0" promptText="Translation workspace" />

    <Label fx:id="statusLabel" layoutX="20.0" layoutY="485.0" prefHeight="40.0" prefWidth="500.0" text="Status: Ready" />

    <Button layoutX="540.0" layoutY="50.0" onAction="#handleIdentifyDocuments" prefWidth="180.0" text="Identify Documents" />

    <Button layoutX="540.0" layoutY="90.0" onAction="#handleOpenWorkspace" prefWidth="180.0" text="Open Workspace" />

    <Button layoutX="540.0" layoutY="130.0" onAction="#handleTranslateText" prefWidth="180.0" text="Translate Text" />

    <Button layoutX="540.0" layoutY="170.0" onAction="#handlePreserveFormat" prefWidth="180.0" text="Preserve Format" />

    <Button layoutX="540.0" layoutY="210.0" onAction="#handleReviewTranslation" prefWidth="180.0" text="Review Translation" />

    <Button layoutX="540.0" layoutY="250.0" onAction="#handleApproveTranslation" prefWidth="180.0" text="Approve Translation" />

    <Button layoutX="540.0" layoutY="290.0" onAction="#handleUploadDocument" prefWidth="180.0" text="Upload Document" />

</AnchorPane>
