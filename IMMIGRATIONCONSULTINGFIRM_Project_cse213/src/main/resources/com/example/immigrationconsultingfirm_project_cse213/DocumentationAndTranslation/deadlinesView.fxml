<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="439.0" prefWidth="749.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.immigrationconsultingfirm_project_cse213.DocumentationAndTranslation.DeadlinesController">

    <Label alignment="CENTER" layoutX="200.0" layoutY="10.0" prefWidth="350.0" text="Manage Document Deadlines">
        <font>
            <Font size="18" />
        </font>
    </Label>

    <TableView fx:id="tableView" layoutX="20.0" layoutY="50.0" prefHeight="192.0" prefWidth="500.0">
        <columns>
            <TableColumn fx:id="docNameColumn" prefWidth="200" text="Document Name" />
            <TableColumn fx:id="deadlineColumn" prefWidth="150" text="Deadline (days left)" />
            <TableColumn fx:id="statusColumn" prefWidth="150" text="Status" />
        </columns>
    </TableView>

    <TextArea fx:id="logArea" layoutX="20.0" layoutY="250.0" prefHeight="96.0" prefWidth="500.0" promptText="Logs / Notifications" />

    <Label fx:id="statusLabel" layoutX="20.0" layoutY="360.0" prefHeight="40.0" prefWidth="500.0" text="Status: Ready" />

    <Button layoutX="540.0" layoutY="50.0" onAction="#handleViewDeadlines" prefHeight="40.0" prefWidth="180.0" text="View Deadlines" />

    <Button layoutX="540.0" layoutY="106.0" onAction="#handleIdentifyUrgent" prefHeight="40.0" prefWidth="180.0" text="Identify Urgent" />

    <Button layoutX="540.0" layoutY="154.0" onAction="#handleSetPriority" prefHeight="40.0" prefWidth="180.0" text="Set Priority" />

    <Button layoutX="540.0" layoutY="202.0" onAction="#handleProcessUrgent" prefHeight="40.0" prefWidth="180.0" text="Process Urgent" />

    <Button layoutX="540.0" layoutY="250.0" onAction="#handleTrackProgress" prefHeight="40.0" prefWidth="180.0" text="Track Progress" />

    <Button layoutX="540.0" layoutY="305.0" onAction="#handleNotifyConsultant" prefHeight="40.0" prefWidth="180.0" text="Notify Consultant" />

    <Button layoutX="540.0" layoutY="360.0" onAction="#handleUpdateDeadlineStatus" prefHeight="40.0" prefWidth="180.0" text="Update Status" />

</AnchorPane>
