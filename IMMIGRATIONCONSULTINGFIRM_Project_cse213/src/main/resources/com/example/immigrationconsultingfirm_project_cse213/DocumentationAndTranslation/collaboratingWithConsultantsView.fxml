<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="506.0" prefWidth="820.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.immigrationconsultingfirm_project_cse213.DocumentationAndTranslation.CollaboratingWithConsultantsController">

    <Label alignment="CENTER" layoutX="265.0" prefHeight="30.0" prefWidth="300.0" text="Collaborate with Consultants">
        <font>
            <Font size="18.0" />
        </font>
    </Label>

    <TextArea fx:id="messageArea" layoutX="40.0" layoutY="338.0" prefHeight="51.0" prefWidth="650.0" promptText="Enter or read messages here" />

    <Label fx:id="statusLabel" layoutX="40.0" layoutY="416.0" prefHeight="39.0" prefWidth="400.0" text="Status" />

    <TableView fx:id="tableView" layoutX="190.0" layoutY="40.0" prefHeight="280.0" prefWidth="450.0">
        <columns>
            <TableColumn fx:id="docNameColumn" prefWidth="225.0" text="Document Name" />
            <TableColumn fx:id="statusColumn" prefWidth="225.0" text="Status" />
        </columns>
    </TableView>

    <Button layoutX="25.0" layoutY="87.0" onAction="#handleReceiveRequest" prefHeight="45.0" prefWidth="150.0" text="Receive Request" />
    <Button layoutX="25.0" layoutY="146.0" onAction="#handleReviewCase" prefHeight="45.0" prefWidth="150.0" text="Review Case" />
    <Button layoutX="659.0" layoutY="146.0" onAction="#handleRespondFeedback" prefHeight="45.0" prefWidth="150.0" text="Respond Feedback" />
    <Button layoutX="659.0" layoutY="202.0" onAction="#handleRequestMissingDocs" prefHeight="45.0" prefWidth="150.0" text="Request Missing Docs" />
    <Button layoutX="509.0" layoutY="416.0" onAction="#handleUpdateNotes" prefHeight="39.0" prefWidth="150.0" text="Update Notes" />
    <Button layoutX="659.0" layoutY="87.0" onAction="#handleUpdateStatus" prefHeight="45.0" prefWidth="150.0" text="Update Status" />
    <Button layoutX="25.0" layoutY="202.0" onAction="#handleConfirmCompletion" prefHeight="45.0" prefWidth="150.0" text="Confirm Completion" />

</AnchorPane>
