<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="570.0" prefWidth="748.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.immigrationconsultingfirm_project_cse213.DocumentationAndTranslation.ConfidentialityController">

    <Label alignment="CENTER" layoutX="200.0" layoutY="10.0" prefWidth="350.0" text="Maintain Document Confidentiality">
        <font>
            <Font size="18" />
        </font>
    </Label>

    <TableView fx:id="tableView" layoutX="20.0" layoutY="50.0" prefHeight="250.0" prefWidth="500.0">
        <columns>
            <TableColumn fx:id="docNameColumn" prefWidth="194.0" text="Document Name" />
            <TableColumn fx:id="accessLevelColumn" prefWidth="156.0" text="Access Level" />
            <TableColumn fx:id="statusColumn" prefWidth="150" text="Status" />
        </columns>
    </TableView>

    <TextArea fx:id="logArea" layoutX="32.0" layoutY="372.0" prefHeight="96.0" prefWidth="500.0" promptText="Access logs / Security incidents" />

    <Label fx:id="statusLabel" layoutX="32.0" layoutY="490.0" prefHeight="49.0" prefWidth="500.0" text="Status: Ready" />

    <Button layoutX="532.0" layoutY="83.0" onAction="#handleRestrictAccess" prefHeight="39.0" prefWidth="180.0" text="Restrict Access" />

    <Button layoutX="532.0" layoutY="136.0" onAction="#handleEncryptDocument" prefHeight="39.0" prefWidth="180.0" text="Encrypt Storage" />

    <Button layoutX="532.0" layoutY="183.0" onAction="#handleMonitorLogs" prefHeight="39.0" prefWidth="180.0" text="Monitor Logs" />

    <Button layoutX="532.0" layoutY="232.0" onAction="#handleDetectUnauthorized" prefHeight="39.0" prefWidth="180.0" text="Detect Unauthorized Access" />

    <Button layoutX="443.0" layoutY="311.0" onAction="#handleBlockUser" prefHeight="39.0" prefWidth="141.0" text="Block Suspicious User" />

    <Button layoutX="20.0" layoutY="311.0" onAction="#handleNotifyAdmin" prefHeight="39.0" prefWidth="180.0" text="Notify Admin" />

    <Button layoutX="237.0" layoutY="311.0" onAction="#handleRecordIncident" prefHeight="39.0" prefWidth="180.0" text="Record Incident" />

</AnchorPane>
