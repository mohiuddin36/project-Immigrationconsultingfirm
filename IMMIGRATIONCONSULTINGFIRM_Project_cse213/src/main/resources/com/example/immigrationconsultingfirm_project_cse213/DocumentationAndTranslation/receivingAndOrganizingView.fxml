<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="471.0" prefWidth="705.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.example.immigrationconsultingfirm_project_cse213.DocumentationAndTranslation.ReceivingAndOrganizingController">

    

    <Label layoutX="23.0" layoutY="61.0" text="Username" />

    <TextField fx:id="usernameField" layoutX="95.0" layoutY="56.0" promptText="Enter Username" />

    <Label layoutX="25.0" layoutY="92.0" text="Password" />

    <TextField fx:id="passwordField" layoutX="84.0" layoutY="88.0" promptText="Enter Password" />

    <Button layoutX="27.0" layoutY="125.0" onAction="#handleLogin" prefHeight="36.0" prefWidth="122.0" text="Login" />


    <Label fx:id="titleLabel" layoutX="219.0" layoutY="11.0" prefHeight="36.0" prefWidth="239.0" text="   Receive and organize client documents" />






    <TextField fx:id="searchField" layoutX="27.0" layoutY="220.0" prefHeight="25.0" prefWidth="278.0" promptText="Search document" />

    <Label fx:id="statusLabel" layoutX="17.0" layoutY="171.0" prefHeight="25.0" prefWidth="305.0" text="Status" />




    <TableView fx:id="tableView" layoutX="358.0" layoutY="62.0" prefHeight="337.0" prefWidth="317.0">

        <columns>
            <TableColumn fx:id="fileNameColumn" prefWidth="158.0" text="File Name" />
            <TableColumn fx:id="fileTypeColumn" prefWidth="158.0" text="File Type" />
        </columns>

    </TableView>



    <Button layoutX="18.0" layoutY="287.0" onAction="#handleAccess" text="Access Client Case" />


    <Button layoutX="173.0" layoutY="287.0" onAction="#handleView" text="View Documents" />


    <Button layoutX="23.0" layoutY="343.0" onAction="#handleDownload" text="Download" />


    <Button layoutX="173.0" layoutY="343.0" onAction="#handleCategorize" text="Categorize" />


    <Button layoutX="29.0" layoutY="392.0" onAction="#handleRename" text="Rename" />

    <!-- Activity 6 -->
    <Button layoutX="174.0" layoutY="392.0" onAction="#handleUpdateStatus" text="Update Status" />

</AnchorPane>
