<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600" prefWidth="900" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.immigrationconsultingfirm_project_cse213.DocumentationAndTranslation.ReceivingAndOrganizingController">


    <Label fx:id="titleLabel" layoutX="250" layoutY="10" text="Goal 1: Receive And Organize Client Documents" />


    <Label layoutX="50" layoutY="50" text="Username:" />
    <TextField fx:id="usernameField" layoutX="130" layoutY="45" />

    <Label layoutX="50" layoutY="90" text="Password:" />

    <Button layoutX="300" layoutY="65" onAction="#handleLogin" text="Login" />


    <Label fx:id="statusLabel" layoutX="50" layoutY="130" text="Status: Not Logged In" />


    <TableView fx:id="tableGoal1" layoutX="50" layoutY="170" prefHeight="250" prefWidth="800">

        <columns>
            <TableColumn fx:id="eventCol" prefWidth="100" text="Event" />
            <TableColumn fx:id="descCol" prefWidth="500" text="Description" />
            <TableColumn fx:id="typeCol" prefWidth="200" text="Type" />
        </columns>
    </TableView>

    
    <Button layoutX="50" layoutY="450" onAction="#handleView" text="View Docs" />
    <Button layoutX="150" layoutY="450" onAction="#handleDownload" text="Download" />
    <Button layoutX="260" layoutY="450" onAction="#handleCategorize" text="Categorize" />
    <Button layoutX="390" layoutY="450" onAction="#handleRename" text="Rename" />
    <Button layoutX="500" layoutY="450" onAction="#handleUpdate" text="Update Status" />
   <TextField fx:id="passwordTF" layoutX="130.0" layoutY="86.0" />

</AnchorPane>
