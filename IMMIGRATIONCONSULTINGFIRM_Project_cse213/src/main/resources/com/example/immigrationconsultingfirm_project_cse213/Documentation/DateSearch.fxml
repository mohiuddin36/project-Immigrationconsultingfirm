<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400" prefWidth="600" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.immigrationconsultingfirm_project_cse213.Documentation.DateSearchController">

    <children>

        <Label alignment="CENTER" layoutX="220" layoutY="20" prefHeight="31.0" prefWidth="136.0" text="Search Clients by Date" />

        <!-- DatePicker -->
        <Label layoutX="120" layoutY="70" text="Select Date:" />

        <DatePicker fx:id="datePicker" layoutX="220" layoutY="65" />

        <!-- Button -->
        <Button layoutX="420" layoutY="65" onAction="#searchOA" text="Search" />

        <!-- Table -->
        <TableView fx:id="table" layoutX="50" layoutY="120" prefHeight="250" prefWidth="500">

            <columns>
                <TableColumn fx:id="nameTC" prefWidth="120" text="Name" />
                <TableColumn fx:id="idTC" prefWidth="100" text="ID" />
                <TableColumn fx:id="docTC" prefWidth="150" text="Document Type" />
                <TableColumn fx:id="dateTC" prefWidth="120" text="Date" />
            </columns>

        </TableView>

    </children>
</AnchorPane>
