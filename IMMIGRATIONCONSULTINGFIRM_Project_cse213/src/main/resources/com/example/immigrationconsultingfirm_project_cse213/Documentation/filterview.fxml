<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400" prefWidth="600" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.immigrationconsultingfirm_project_cse213.Documentation.FilterController">

    <children>

        <Label alignment="CENTER" layoutX="201.0" layoutY="22.0" prefHeight="37.0" prefWidth="198.0" text="Filter Clients by Document Type" />

        <!-- ComboBox -->
        <Label layoutX="120" layoutY="70" text="Select Type:" />

        <ComboBox fx:id="typeCombo" layoutX="220" layoutY="65" prefWidth="180" />

        <!-- Button (NO fx:id, only action) -->
        <Button layoutX="420" layoutY="65" onAction="#filterOA" text="Filter" />

        <!-- Table -->
        <TableView fx:id="table" layoutX="50" layoutY="120" prefHeight="250" prefWidth="500">

            <columns>
                <TableColumn fx:id="nameTC" prefWidth="120" text="Name" />
                <TableColumn fx:id="idTC" prefWidth="100" text="ID" />
                <TableColumn fx:id="docTC" prefWidth="150" text="Document Type" />
                <TableColumn fx:id="dateTC" prefWidth="120" text="Date" />
            </columns>

        </TableView>

    </children>
</AnchorPane>
