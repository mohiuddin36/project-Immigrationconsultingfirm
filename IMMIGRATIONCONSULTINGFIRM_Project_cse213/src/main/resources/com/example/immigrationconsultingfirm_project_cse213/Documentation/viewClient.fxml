<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="409.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.immigrationconsultingfirm_project_cse213.Documentation.ViewClientController">

    <children>

        <!-- Title -->
        <Label alignment="CENTER" layoutX="212.0" layoutY="20" prefHeight="40.0" prefWidth="161.0" text="All Clients">
         <font>
            <Font size="17.0" />
         </font></Label>

        <!-- Table -->
        <TableView fx:id="clientTable" layoutX="50.0" layoutY="87.0" prefHeight="250" prefWidth="500">

            <columns>

                <TableColumn fx:id="nameTC" prefWidth="120" text="Name" />
                <TableColumn fx:id="idTC" prefWidth="100" text="ID" />
                <TableColumn fx:id="docTypeTC" prefWidth="150" text="Document Type" />
                <TableColumn fx:id="dateTC" prefWidth="120" text="Date" />

            </columns>

        </TableView>

        <!-- Refresh Button -->
        <Button layoutX="244.0" layoutY="346.0" onAction="#loadDataOA" prefHeight="40.0" prefWidth="97.0" text="Load Data" />

    </children>
</AnchorPane>
